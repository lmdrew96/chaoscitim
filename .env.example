# Copy to .env.local and fill in. .env.local is gitignored.

# Neon Postgres connection string. From the Neon dashboard, "Connection
# Details" → "psql" or pooler URL. Drizzle uses `prepare: false` so the
# pooler URL is fine.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk auth. Grab the publishable + secret keys from the Clerk dashboard
# (https://dashboard.clerk.com) → API Keys. The dev instance is fine for
# local work.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
